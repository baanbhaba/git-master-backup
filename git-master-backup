#!/bin/bash

# ============================================================
# Script: Git Master Backup
# Description: Scans all drives for Git repos and backs them up
# Author: baanbhaba & ai
# ============================================================

# ---------------------- COLORS ------------------------------
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# ---------------------- TIMESTAMP ----------------------------
TIMESTAMP=$(date '+%d/%m %H:%M')

# ---------------------- SCAN DIRECTORIES ---------------------
SCAN_DIRS=(
    "$HOME"
    "/run/media/baanbhaba/External"
)

# ---------------------- EXCLUSIONS ---------------------------
# Repos to skip (add full paths here)
SKIP_REPOS=(
    # "$HOME/.cache"
    # "$HOME/.local/share"
)

# ---------------------- START --------------------------------
echo ""
echo -e "${BLUE}╔════════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║                 🚀 GIT MASTER BACKUP               ║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "${YELLOW}🔍 Scanning for Git repositories...${NC}"
echo -e "${YELLOW}📅 Timestamp:${NC} $TIMESTAMP"
echo ""

# ---------------------- FIND AND PROCESS ---------------------
find "${SCAN_DIRS[@]}" -type d -name ".git" 2>/dev/null | while read -r gitdir; do
    
    # Get the parent directory (the repo root)
    repo="$(dirname "$gitdir")"
    
    # Check if repo is in skip list
    skip=0
    for skip_path in "${SKIP_REPOS[@]}"; do
        if [[ "$repo" == "$skip_path"* ]]; then
            skip=1
            break
        fi
    done
    [[ $skip -eq 1 ]] && continue
    
    echo -e "${GREEN}=========================================${NC}"
    echo -e "${GREEN}📁 Repository:${NC} $repo"
    echo -e "${GREEN}=========================================${NC}"
    
    # Change to repo directory
    cd "$repo" || continue
    
    # ---------------------- VALIDATE REPO ----------------------
    if ! git rev-parse --git-dir > /dev/null 2>&1; then
        echo -e "${RED}❌ Not a valid git repo, skipping...${NC}"
        echo ""
        continue
    fi
    
    # ---------------------- CHECK REMOTE ----------------------
    remote_url=$(git remote get-url origin 2>/dev/null)
    
    # Skip if no remote
    if [[ -z "$remote_url" ]]; then
        echo -e "${RED}❌ No remote configured, skipping...${NC}"
        echo ""
        continue
    fi
    
    # Skip HTTPS repos
    if [[ "$remote_url" == https://* ]]; then
        echo -e "${RED}🔒 HTTPS repo detected, skipping...${NC}"
        echo -e "${RED}   (Use SSH instead: git@github.com:user/repo.git)${NC}"
        echo ""
        continue
    fi
    
    # Show remote type
    if [[ "$remote_url" == git@* ]]; then
        echo -e "${GREEN}✅ SSH repo detected${NC}"
    fi
    
    # ---------------------- CHECK BRANCH ----------------------
    current_branch=$(git branch --show-current 2>/dev/null)
    if [[ -z "$current_branch" ]]; then
        echo -e "${RED}❌ No branch checked out, skipping...${NC}"
        echo ""
        continue
    fi
    echo -e "${BLUE}🌿 Branch:${NC} $current_branch"
    
    # ---------------------- CHECK FOR CHANGES -----------------
    if [[ -n $(git status --porcelain) ]]; then
        echo -e "${YELLOW}📝 Changes detected, committing...${NC}"
        
        # Show what's changed
        git status --porcelain | head -5
        if [[ $(git status --porcelain | wc -l) -gt 5 ]]; then
            echo -e "${YELLOW}   ... and $(($(git status --porcelain | wc -l) - 5)) more${NC}"
        fi
        
        # Add all changes
        git add .
        
        # Commit with timestamp
        git commit -m "Auto-backup: $TIMESTAMP"
        
        # ---------------------- PUSH WITH AUTO-UPSTREAM ----------
        echo -e "${YELLOW}📤 Pushing to remote...${NC}"
        
        if git push 2>&1; then
            echo -e "${GREEN}✅ Successfully pushed!${NC}"
        else
            # If push fails, try setting upstream and push again
            echo -e "${YELLOW}   Retrying with --set-upstream...${NC}"
            if git push --set-upstream origin "$current_branch" 2>&1; then
                echo -e "${GREEN}✅ Upstream set and push successful!${NC}"
            else
                echo -e "${RED}❌ Push failed!${NC}"
                echo -e "${YELLOW}   You may need to pull first or check your connection${NC}"
            fi
        fi
    else
        echo -e "${GREEN}💤 No changes to commit.${NC}"
    fi
    
    echo ""
done

# ---------------------- DONE ---------------------------------
echo -e "${GREEN}╔════════════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║                🎉 ALL REPOS PROCESSED!             ║${NC}"
echo -e "${GREEN}╚════════════════════════════════════════════════════╝${NC}"
echo ""
